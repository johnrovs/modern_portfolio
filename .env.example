# Copy this file to .env.local and fill in your real EmailJS values.
# .env.local is already gitignored, so your keys won't get committed.
# See README.md → "Wiring up the contact form" for the full setup walkthrough.

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
